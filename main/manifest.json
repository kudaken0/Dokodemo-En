{
  "manifest_version": 3,
  "name": "どこでも円",
  "version": "1.2.0",
  "description": "リアルタイムで現在の為替レートを取得しそれに基づき日本円に変換します。",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["css/content_style.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "img/48.png",
    "128": "img/128.png"
  }
}